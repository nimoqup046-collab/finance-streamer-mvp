# ========================================
# AI 模型配置（选择一个使用）
# ========================================

# 方式1：使用智谱 GLM（默认推荐，优先尝试 GLM-5；若账号权限不足可改为 glm-4.7）
AI_PROVIDER=zhipu
ZHIPU_API_KEY=your-zhipu-api-key
ZHIPU_API_BASE=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-5

# 可选：开启 OpenRouter 高质量内容路由（仅直播稿 / 公众号）
# OPENROUTER_ENABLE_QUALITY_ROUTING=true
# OPENROUTER_API_KEY=your-openrouter-api-key
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=
# OPENROUTER_APP_TITLE=finance-streamer-mvp
# OPENROUTER_STREAM_MODELS=anthropic/claude-sonnet-4.6,google/gemini-3.1-pro-preview,openai/gpt-5.1
# OPENROUTER_ARTICLE_MODELS=anthropic/claude-sonnet-4.6,openai/gpt-5.1,google/gemini-3.1-pro-preview

# 方式2：使用豆包
# AI_PROVIDER=doubao
# DOUBAO_API_KEY=your-doubao-api-key
# DOUBAO_API_BASE=https://ark.cn-beijing.volces.com/api/v3
# DOUBAO_ENDPOINT_ID=
# DOUBAO_MODEL=doubao-1-5-pro-32k-250115

# 方式3：使用 Anthropic Claude Sonnet 4.6
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your-anthropic-api-key
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# 方式4：使用 OpenAI
# AI_PROVIDER=openai
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# ========================================
# 服务配置
# ========================================
PORT=8000

# 生产环境请填写具体域名，多个用逗号分隔，不要使用 *
# 例如：CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=https://yourdomain.com

# API 认证密钥（生产环境强烈建议设置，设置后请求需携带 X-API-Key 请求头）
# 例如：API_KEY=replace-with-a-long-random-string
API_KEY=replace-with-a-long-random-string

# ========================================
# 新闻缓存时间（分钟）
# ========================================
NEWS_CACHE_MINUTES=30
